{
  "manifest_version": 3,
  "name": "LinkedIn Saved Item Search",
  "version": "1.0.0",
  "description": "Search across all your saved LinkedIn posts, articles, and jobs — something LinkedIn itself doesn't let you do.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/my-items/saved-posts/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
